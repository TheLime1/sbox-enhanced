{
  "name": "sbox-enhanced",
  "displayName": "s&box Enhanced",
  "version": "1.0.0",
  "description": "Launch s&box games, open community trackers, and export creator stats from sbox.game.",
  "scripts": {
    "dev": "pnpm dev:chrome",
    "dev:chrome": "plasmo dev --target=chrome-mv3",
    "dev:firefox": "plasmo dev --target=firefox-mv3",
    "build": "pnpm build:chrome && pnpm build:firefox",
    "build:chrome": "plasmo build --target=chrome-mv3",
    "build:firefox": "plasmo build --target=firefox-mv3",
    "package": "pnpm package:chrome && pnpm package:firefox",
    "package:chrome": "pnpm build:chrome && plasmo package --target=chrome-mv3",
    "package:firefox": "pnpm build:firefox && plasmo package --target=firefox-mv3",
    "lint": "eslint .",
    "lint:firefox": "web-ext lint --source-dir build/firefox-mv3-prod --output=json > build/web-ext-lint.json && node scripts/check-web-ext-lint.mjs",
    "verify:manifests": "node scripts/verify-manifests.mjs",
    "release:firefox": "pnpm build && plasmo package --target=firefox-mv3 && pnpm verify:manifests && pnpm lint:firefox && node scripts/package-source.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm verify:manifests && pnpm lint:firefox"
  },
  "dependencies": {
    "@fontsource/poppins": "^5.2.7",
    "@plasmohq/parcel-transformer-inject-env": "^0.2.12",
    "plasmo": "^0.90.5",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/chrome": "^0.2.2",
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9.39.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^16.5.0",
    "jsdom": "^27.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.0",
    "vitest": "^4.0.15",
    "web-ext": "10.5.0"
  },
  "manifest": {
    "manifest_version": 3,
    "permissions": [],
    "browser_specific_settings": {
      "gecko": {
        "id": "@sbox-enhanced",
        "strict_min_version": "140.0",
        "data_collection_permissions": {
          "required": [
            "none"
          ]
        }
      }
    }
  },
  "packageManager": "pnpm@11.7.0"
}
